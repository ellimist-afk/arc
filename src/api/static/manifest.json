{
    "name": "TalkBot - AI Streaming Assistant",
    "short_name": "TalkBot",
    "description": "AI-powered streaming assistant for Twitch with real-time chat interaction and voice synthesis",
    "start_url": "/dashboard",
    "scope": "/",
    "display": "standalone",
    "orientation": "portrait-primary",
    "theme_color": "#9146FF",
    "background_color": "#0D1117",
    "lang": "en-US",
    "dir": "ltr",
    
    "icons": [
        {
            "src": "/static/favicon.ico",
            "sizes": "16x16 32x32 48x48",
            "type": "image/x-icon",
            "purpose": "any"
        },
        {
            "src": "/static/icons/icon-192x192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any maskable"
        },
        {
            "src": "/static/icons/icon-512x512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any maskable"
        }
    ],
    
    "screenshots": [],
    
    "categories": [
        "streaming",
        "entertainment",
        "tools",
        "social",
        "productivity"
    ],
    
    "shortcuts": [
        {
            "name": "Dashboard",
            "short_name": "Dashboard", 
            "description": "View bot status and activity",
            "url": "/dashboard"
        },
        {
            "name": "Settings",
            "short_name": "Settings",
            "description": "Configure bot behavior and personality", 
            "url": "/settings"
        },
        {
            "name": "Analytics",
            "short_name": "Analytics",
            "description": "View streaming metrics and insights",
            "url": "/analytics"
        }
    ],
    
    "related_applications": [],
    "prefer_related_applications": false,
    
    "protocol_handlers": [
        {
            "protocol": "web+talkbot",
            "url": "/deep-link?action=%s"
        }
    ],
    
    "file_handlers": [
        {
            "action": "/file-handler",
            "accept": {
                "application/json": [".json"],
                "text/plain": [".txt", ".log"]
            }
        }
    ],
    
    "share_target": {
        "action": "/share-handler",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "file",
                    "accept": ["image/*", "text/plain", "application/json"]
                }
            ]
        }
    },
    
    "launch_handler": {
        "client_mode": "focus-existing"
    },
    
    "id": "talkbot-streaming-assistant",
    "handle_links": "preferred",
    
    "edge_side_panel": {
        "preferred_width": 400
    },
    
    "display_override": [
        "window-controls-overlay",
        "standalone",
        "minimal-ui",
        "browser"
    ]
}